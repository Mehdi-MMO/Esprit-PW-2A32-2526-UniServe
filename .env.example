# Copy to `.env` and adjust (`.env` is gitignored).
#
# If you see: Access denied for user 'root'@'...' (using password: NO)
# — set DB_PASSWORD to your MySQL user password (often empty for XAMPP root on localhost only).

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=uniserve
DB_USER=root
DB_PASSWORD=

# PHP runs in Docker while MySQL is on the host: try host.docker.internal as DB_HOST.
# MYSQL_ROOT_PASSWORD is read if DB_PASSWORD is unset (some Docker images).
