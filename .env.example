# Copier vers `.env` et renseigner les secrets. Chargé au démarrage (Database::ensureEnvLoaded).

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=uniserve
DB_USER=root
DB_PASSWORD=

# --- SMTP (mot de passe oublié, OTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=UniServe

# --- Alertes / risque connexion (OTP étape supplémentaire si risque medium/high) ---
LOGIN_ALERT_EMAIL_ENABLED=1
# 1 = appeler Groq pour affiner le score (nécessite GROQ_API_KEY)
LOGIN_RISK_AI_ENABLED=1
# 1 = activer l’OTP email sur connexions à risque (nécessite SMTP)
LOGIN_RISK_STEP_UP_ENABLED=0

# --- Groq (assistant flottant + brief agenda) — API compatible OpenAI ---
# Clé : https://console.groq.com/keys (préfixe typique gsk_)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CALENDAR_BRIEF_AI_ENABLED=1
# Optionnel : modèle dédié au brief (sinon = GROQ_MODEL)
CALENDAR_BRIEF_GROQ_MODEL=
# Durée de vie (secondes) du cache par utilisateur de la synthèse hebdo (défaut 86400 = 24h).
# Le cache est invalidé automatiquement dès que l’agenda change (empreinte des événements)
# ou quand l’utilisateur clique sur « Actualiser » (refresh=1).
CALENDAR_BRIEF_CACHE_TTL=86400
# Optionnel : dossier absolu pour les fichiers JSON du cache (défaut : Model/storage/cache/calendar-brief/).
# CALENDAR_BRIEF_CACHE_DIR=

# 1 = suggestion IA (Groq) sur la description des demandes de service (GROQ_API_KEY) — inclut le contexte « Mes demandes » (extraits) + synthèse portail
DEMANDE_AI_DESCRIPTION_ENABLED=1

# 1 = modération Groq sur création / édition de demandes de service (nécessite GROQ_API_KEY)
DEMANDE_GROQ_MODERATION_ENABLED=0

# 1 = bouton « Vérification IA » sur la liste admin des demandes de service (nécessite GROQ_API_KEY)
DEMANDE_STAFF_AI_CHECK_ENABLED=1

# --- Événements payants (Stripe Checkout) — colonne evenements.prix_ticket incluse dans db/uniserve_full.sql ---
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd
# Indicatif affiché sur la fiche événement (USD → TND), pas utilisé par Stripe
USD_TO_TND_RATE=3.10

# --- DOCAC / certifications (quiz IA) — tables incluses dans db/uniserve_full.sql ---
# auto = Ollama puis Groq si besoin ; ollama | groq pour forcer
DOCAC_QUIZ_AI=auto
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b

LOGIN_RISK_MEDIUM_THRESHOLD=35
LOGIN_RISK_HIGH_THRESHOLD=70
LOGIN_RISK_ADMIN_ALERT_EMAIL=

# --- Inscription / e-mail institutionnel ---
# Domaines autorisés pour l’inscription (liste séparée par des virgules). Vide = valeur par défaut du contrôleur.
INSTITUTIONAL_EMAIL_DOMAINS=gmail.com

# Secours PDO si `DB_PASSWORD` est vide (ex. environnement Docker).
MYSQL_ROOT_PASSWORD=
